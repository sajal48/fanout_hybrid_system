{
  "title": "Twitter Feed System - Application Logs",
  "tags": ["logs", "twitter-feed", "loki"],
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Log Volume Over Time",
      "type": "graph",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(rate({job=\"twitter-feed-app\"}[1m])) by (level)",
          "legendFormat": "{{level}}",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "DS_LOKI"
          }
        }
      ],
      "yaxes": [
        {"format": "logs/s", "label": "Logs per second"},
        {"format": "short"}
      ]
    },
    {
      "id": 2,
      "title": "Total Logs",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"twitter-feed-app\"}[5m]))",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "DS_LOKI"
          }
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "id": 3,
      "title": "Error Logs Count",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 8},
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"twitter-feed-app\"} |~ \"ERROR\"[5m]))",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "DS_LOKI"
          }
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 10, "color": "yellow"},
              {"value": 50, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Warning Logs Count",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"twitter-feed-app\"} |~ \"WARN\"[5m]))",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "DS_LOKI"
          }
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 20, "color": "yellow"},
              {"value": 100, "color": "orange"}
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Log Level Distribution",
      "type": "piechart",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 8},
      "targets": [
        {
          "expr": "sum by (level) (count_over_time({job=\"twitter-feed-app\"} | json | __error__=\"\" [5m]))",
          "legendFormat": "{{level}}",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "DS_LOKI"
          }
        }
      ]
    },
    {
      "id": 6,
      "title": "Recent Application Logs",
      "type": "logs",
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 12},
      "targets": [
        {
          "expr": "{job=\"twitter-feed-app\"}",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "DS_LOKI"
          }
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "id": 7,
      "title": "Error Logs Only",
      "type": "logs",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 24},
      "targets": [
        {
          "expr": "{job=\"twitter-feed-app\"} |~ \"(?i)error|exception|failed\"",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "DS_LOKI"
          }
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "id": 8,
      "title": "API Request Logs",
      "type": "logs",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 34},
      "targets": [
        {
          "expr": "{job=\"twitter-feed-app\"} |~ \"POST|GET|PUT|DELETE|PATCH\"",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "DS_LOKI"
          }
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "id": 9,
      "title": "Database Query Logs",
      "type": "logs",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 44},
      "targets": [
        {
          "expr": "{job=\"twitter-feed-app\"} |~ \"(?i)sql|query|select|insert|update|delete from|cassandra|redis|postgres\"",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "DS_LOKI"
          }
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ]
}
