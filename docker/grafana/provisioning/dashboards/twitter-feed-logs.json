{
  "title": "Twitter Feed System - Application Logs",
  "tags": ["logs", "twitter-feed", "loki"],
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": {
    "list": [
       {
         "name": "TraceId",
         "type": "textbox",
         "label": "Trace ID",
         "current": {"text": "", "value": ""},
         "options": [],
         "multi": false,
         "includeAll": false,
         "allValue": null,
         "skipUrlSync": false,
         "description": "Filter logs by trace ID (leave empty for all)"
       },
      {
        "name": "LogLevel",
        "type": "multi-select",
        "label": "Log Level",
        "current": {"text": "All", "value": ["DEBUG", "INFO", "WARN", "ERROR"]},
        "options": [
          {"text": "DEBUG", "value": "DEBUG"},
          {"text": "INFO", "value": "INFO"},
          {"text": "WARN", "value": "WARN"},
          {"text": "ERROR", "value": "ERROR"}
        ],
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "skipUrlSync": false
      },
       {
         "name": "Logger",
         "type": "textbox",
         "label": "Logger Name",
         "current": {"text": "", "value": ""},
         "options": [],
         "multi": false,
         "includeAll": false,
         "allValue": null,
         "skipUrlSync": false,
         "description": "Filter by logger name (e.g., com.twitter.feed)"
       },
       {
         "name": "UserId",
         "type": "textbox",
         "label": "User ID",
         "current": {"text": "", "value": ""},
         "options": [],
         "multi": false,
         "includeAll": false,
         "allValue": null,
         "skipUrlSync": false,
         "description": "Filter logs by user ID"
       }
    ]
  },
  "panels": [
    {
      "id": 0,
      "title": "Log Search Filters",
      "type": "row",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
    },
    {
      "id": 1,
      "title": "Log Volume Over Time",
      "type": "graph",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 1},
      "targets": [
        {
          "expr": "sum(rate({job=\"twitter-feed-app\"}[1m])) by (level)",
          "legendFormat": "{{level}}",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "DS_LOKI"
          }
        }
      ],
      "yaxes": [
        {"format": "logs/s", "label": "Logs per second"},
        {"format": "short"}
      ]
    },
    {
      "id": 2,
      "title": "Total Logs",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 9},
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"twitter-feed-app\"}[5m]))",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "DS_LOKI"
          }
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "id": 3,
      "title": "Error Logs Count",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 9},
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"twitter-feed-app\"} |~ \"ERROR\"[5m]))",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "DS_LOKI"
          }
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 10, "color": "yellow"},
              {"value": 50, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Warning Logs Count",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 9},
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"twitter-feed-app\"} |~ \"WARN\"[5m]))",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "DS_LOKI"
          }
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 20, "color": "yellow"},
              {"value": 100, "color": "orange"}
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Log Level Distribution",
      "type": "piechart",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 9},
      "targets": [
        {
          "expr": "sum by (level) (count_over_time({job=\"twitter-feed-app\"} | json | __error__=\"\" [5m]))",
          "legendFormat": "{{level}}",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "DS_LOKI"
          }
        }
      ]
    },
    {
      "id": 6,
      "title": "Recent Application Logs (with Trace ID)",
      "type": "logs",
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 13},
      "targets": [
        {
           "expr": "{job=\"twitter-feed-app\"} | json | level=~\"${LogLevel:pipe}\"",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "DS_LOKI"
          }
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "id": 7,
      "title": "Trace ID Search",
      "type": "logs",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 25},
      "targets": [
        {
          "expr": "{job=\"twitter-feed-app\"} | json | traceId=~\"${TraceId}\"",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "DS_LOKI"
          }
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "id": 8,
      "title": "Error Logs Only",
      "type": "logs",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 35},
      "targets": [
        {
          "expr": "{job=\"twitter-feed-app\"} |~ \"(?i)error|exception|failed\"",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "DS_LOKI"
          }
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "id": 9,
      "title": "API Request Logs (with Trace ID)",
      "type": "logs",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 45},
      "targets": [
        {
          "expr": "{job=\"twitter-feed-app\"} | json | logger_name=~\".*Controller.*\"",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "DS_LOKI"
          }
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "id": 10,
      "title": "Database Query Logs (with Trace ID)",
      "type": "logs",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 55},
      "targets": [
        {
          "expr": "{job=\"twitter-feed-app\"} | json | logger_name=~\".*SQL.*|.*Repository.*\"",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "DS_LOKI"
          }
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "id": 11,
      "title": "User-Specific Logs",
      "type": "logs",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 65},
      "targets": [
        {
           "expr": "{job=\"twitter-feed-app\"} | json | message=~\".*${UserId}.*\"",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "DS_LOKI"
          }
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ]
}
