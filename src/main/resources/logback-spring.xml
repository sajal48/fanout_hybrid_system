<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- Console appender with JSON format -->
    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeContext>true</includeContext>
            <includeMdc>true</includeMdc>
            <includeStructuredArguments>true</includeStructuredArguments>
            <includeTags>true</includeTags>
            <includeCallerData>false</includeCallerData>
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSSX</timestampPattern>
            <customFields>{"application":"twitter-feed-system","environment":"${SPRING_PROFILES_ACTIVE:-default}"}</customFields>
        </encoder>
    </appender>

    <!-- Console appender with plain text format (includes trace ID) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- Pattern includes traceId, spanId from Micrometer Tracing -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [traceId:%X{traceId}] [spanId:%X{spanId}] [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- File appender with trace ID -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/application.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/application-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>100MB</totalSizeCap>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeContext>true</includeContext>
            <includeMdc>true</includeMdc>
            <customFields>{"application":"twitter-feed-system"}</customFields>
        </encoder>
    </appender>

    <!-- Profile-specific configuration -->
    <springProfile name="docker">
        <root level="INFO">
            <appender-ref ref="CONSOLE_JSON"/>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

    <springProfile name="!docker">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

    <!-- Application-specific loggers with trace IDs -->
    <logger name="com.twitter.feed" level="DEBUG"/>
    <logger name="com.twitter.feed.post.controller" level="DEBUG"/>
    <logger name="com.twitter.feed.feed.controller" level="DEBUG"/>
    <logger name="com.twitter.feed.user.controller" level="DEBUG"/>
    <logger name="com.twitter.feed.post.service" level="DEBUG"/>
    <logger name="com.twitter.feed.feed.service" level="DEBUG"/>
    <logger name="com.twitter.feed.fanout.strategy" level="DEBUG"/>
    <logger name="com.twitter.feed.feed.repository" level="DEBUG"/>
    <logger name="org.springframework.data.cassandra" level="INFO"/>
    <logger name="org.hibernate.SQL" level="DEBUG"/>
    <logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="TRACE"/>

    <!-- Performance logging -->
    <logger name="com.twitter.feed.fanout" level="DEBUG"/>
    <logger name="com.twitter.feed.feed" level="DEBUG"/>

    <!-- Micrometer Tracing logging -->
    <logger name="io.micrometer.tracing" level="INFO"/>
</configuration>
